# Copie para `.env` local. Na Vercel: Settings → Environment Variables.
# Nunca commite `.env` com segredos.

# PostgreSQL (obrigatório)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Segredo para assinar o cookie de sessão — gere uma string longa aleatória (ex.: openssl rand -base64 32)
# OBRIGATÓRIO em produção.
AUTH_SESSION_SECRET=

# URL canónica da app (emails, links absolutos, metadata). Na Vercel pode usar o domínio de preview/production.
# Ex.: https://seudominio.com
APP_URL=
# Alternativa pública (metadata / SEO); pode ser igual a APP_URL.
NEXT_PUBLIC_APP_URL=

# E-mail (produção): https://resend.com — sem isto o reset de senha falha ao enviar.
RESEND_API_KEY=
# Remetente verificado no Resend (domínio próprio). Opcional em dev (usa onboarding@resend.dev).
EMAIL_FROM=

# Opcional: intervalo mínimo entre pedidos de reset de senha (segundos). Padrão 120.
# PASSWORD_RESET_COOLDOWN_SECONDS=120

# Vercel Blob — capas de projeto, avatar, etc. (Storage → Blob no dashboard da Vercel)
# Local: `vercel env pull` após ligar o store ao projeto.
BLOB_READ_WRITE_TOKEN=
